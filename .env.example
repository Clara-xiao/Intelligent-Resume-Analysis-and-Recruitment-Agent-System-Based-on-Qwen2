# ── LLM ───────────────────────────────────────────────────────────────────────
# Option A: Alibaba DashScope (Qwen2.5 official API, OpenAI-compatible)
LLM_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen2.5-72b-instruct

# Option B: Local Ollama  (comment out A, uncomment B)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# Option C: Demo mode — leave LLM_API_KEY empty or set to "demo"
# LLM_API_KEY=demo

# ── Embeddings ────────────────────────────────────────────────────────────────
# Local BGE model (downloaded automatically on first run)
EMBED_MODEL=BAAI/bge-small-zh-v1.5
